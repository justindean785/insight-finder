{
  "$schema": "https://www.designtokens.org/schemas/2025.10/format.json",
  "$description": "Calm, investigative, restrained accent. Cyber-tactical OSINT tool.",
  "color": {
    "$type": "color",
    "background": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.031,
          0.031,
          0.031
        ],
        "hex": "#080808"
      }
    },
    "foreground": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.98,
          0.98,
          0.98
        ],
        "hex": "#fafafa"
      }
    },
    "card": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.078,
          0.078,
          0.078
        ],
        "hex": "#141414"
      }
    },
    "popover": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.059,
          0.059,
          0.059
        ],
        "hex": "#0f0f0f"
      }
    },
    "primary": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.949,
          0.949,
          0.949
        ],
        "hex": "#f2f2f2"
      }
    },
    "muted": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.051,
          0.051,
          0.051
        ],
        "hex": "#0d0d0d"
      }
    },
    "muted-foreground": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.702,
          0.702,
          0.702
        ],
        "hex": "#b3b3b3"
      }
    },
    "destructive": {
      "$value": {
        "colorSpace": "srgb",
        "components": [
          0.937,
          0.267,
          0.267
        ],
        "hex": "#ef4444"
      }
    }
  },
  "spacing": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 16,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 24,
        "unit": "px"
      }
    }
  },
  "rounded": {
    "$type": "dimension",
    "sm": {
      "$value": {
        "value": 4,
        "unit": "px"
      }
    },
    "md": {
      "$value": {
        "value": 6,
        "unit": "px"
      }
    },
    "lg": {
      "$value": {
        "value": 8,
        "unit": "px"
      }
    }
  },
  "typography": {
    "sans": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Geist",
        "fontSize": {
          "value": 16,
          "unit": "px"
        }
      }
    },
    "mono": {
      "$type": "typography",
      "$value": {
        "fontFamily": "Geist Mono",
        "fontSize": {
          "value": 14,
          "unit": "px"
        }
      }
    }
  }
}
