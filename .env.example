# =====================================================================
# Insight Finder — environment schema
# =====================================================================
# Copy to .env (frontend, Vite) or set via `supabase secrets set NAME=***`
# (edge functions). NEVER commit a populated .env.
# =====================================================================

# ---- Frontend (Vite — public, safe to ship in client bundle) ---------
# Find these in Supabase Dashboard > Project Settings > API
VITE_SUPABASE_URL="https://<project-id>.supabase.co"
VITE_SUPABASE_PUBLISHABLE_KEY="<anon / publishable key from dashboard>"
VITE_SUPABASE_PROJECT_ID="<project-id>"

# ---- Edge function secrets (NEVER expose to frontend) ----------------
# Set via: supabase secrets set NAME=*** --env production
#
# REQUIRED — core Supabase (edge function cannot serve requests without these):
SUPABASE_ANON_KEY=""        # Same as VITE_SUPABASE_PUBLISHABLE_KEY — RLS-safe user client in auth.ts
#
# REQUIRED (at least one orchestrator):
MINIMAX_API_KEY=""          # Primary orchestrator (MiniMax-M2.7)
LOVABLE_API_KEY=""          # Fallback orchestrator (Lovable AI gateway / Gemini)
#
# OPTIONAL — alternative orchestrator providers (Tranche 2, env-gated).
# Leave unset to keep MiniMax as the orchestrator (default, unchanged behavior).
# Set a key + ORCHESTRATOR_PROVIDER to move the orchestrator/report turn over.
XAI_API_KEY=""              # xAI Grok (https://api.x.ai/v1)
OPENADAPTER_API_KEY=""      # OpenAdapter gateway key
OPENADAPTER_BASE_URL=""     # OpenAdapter base URL (required with the key)
ORCHESTRATOR_PROVIDER=""    # pin the primary: "" (=minimax) | "grok" | "openadapter"
GROK_ORCHESTRATOR_MODEL_ID=""        # default "grok-4" — confirm current id on x.ai
OPENADAPTER_ORCHESTRATOR_MODEL_ID="" # model id the OpenAdapter gateway serves
#
# OPTIONAL — breach / identity providers:
STOLENTAX_API_KEY=""        # stolen.tax breach + footprint (breach_check, stolentax_footprint)
LEAKCHECK_API_KEY=""        # LeakCheck Pro v2 secondary breach corroboration
DEEPFIND_API_KEY=""         # DeepFind.Me reverse-email, social, and specialty lookups
OATHNET_API_KEY=""          # OathNet breach + stealer logs (100/day)
SYNAPSINT_API_KEY=""        # Synapsint multi-endpoint aggregator (CUT — disabled: dead in prod)
OSINTNOVA_API_KEY=""        # OSINTNova (Bosint) — email + phone
INDICIA_API_KEY=""          # api.indicia.app — US footprint/phone/email/person/address + web-DB
                            # breach aggregator. 6 endpoints only; facial/geolocation/gmail/username
                            # are intentionally NOT wired (hard policy — see tools/indicia.ts).
SOCIALFETCH_API_KEY=""      # TikTok/Instagram/Twitter/Facebook profiles
CORDCAT_API_KEY=""          # Discord snowflake OSINT
HUNTER_API_KEY=""           # Hunter.io email verification + finding
INTELBASE_API_KEY=""        # IntelBase (currently DISABLED in code)
HIBP_API_KEY=""             # Have I Been Pwned v3
SERUS_API_KEY=""           # Serus darkweb scan (0.25 credits/scan; rotate if leaked)
VIRUSTOTAL_API_KEY=""       # VirusTotal v3 domain/IP/file reputation lookups
RAPIDAPI_KEY=""             # RapidAPI Email Breach Search (email-breach-search edge function)
#
# OPTIONAL — web search / scrape:
EXA_API_KEY=""              # Exa neural+keyword search
JINA_API_KEY=""             # Jina Reader (optional — works unauthenticated)
FIRECRAWL_API_KEY=""        # Firecrawl (DISABLED in code — credits exhausted)
GEMINI_API_KEY=""           # Gemini grounded search
PERPLEXITY_API_KEY=""       # Perplexity Sonar
GITHUB_API_TOKEN=""         # GitHub code + user lookups (also reads GITHUB_TOKEN)
OSINT_NAVIGATOR_API_KEY=""  # OSINT Navigator tool recommendation

# ---- Optional — distributed rate limiter (audit F-A3) ----------------
# Set BOTH to upgrade the per-user rate limiter from in-memory to a
# cross-instance Upstash counter. Without these, the function silently
# falls back to the in-memory cap (still functional, per-instance only).
# Free tier: 10k req/day. Sign up: https://upstash.com
# Create a "Global" database (lowest latency from edge functions) and
# copy the REST URL + token from the dashboard.
UPSTASH_REDIS_REST_URL=""   # https://<instance>.upstash.io
UPSTASH_REDIS_REST_TOKEN=""

# ---- Notes for operators --------------------------------------------
# 1. Any time a key is committed to source, shared in chat, or pasted
#    into a doc: ROTATE IT IMMEDIATELY. Treat all keys as compromised
#    the moment they leave the secret store.
# 2. Edge function secrets are project-wide. To rotate:
#       supabase secrets unset NAME
#       supabase secrets set NAME=<new-value>
#       supabase functions deploy osint-agent
# 3. Frontend .env changes need a Vite rebuild + redeploy.
# 4. INTELBASE_ENABLED is hard-coded to false in env.ts; flip after
#    provider health check passes.
# 5. Firecrawl is permanently disabled in code due to credit exhaustion.
